#!/usr/bin/env bash
# Print Claude Code session prompts for this project from ~/.claude/history.jsonl
# Usage: ./bin/claude-prompts-history
# Then manually update specs/prompts.md with the relevant entries.

set -euo pipefail

HISTORY="$HOME/.claude/history.jsonl"
PROJECT="$(pwd)"

if [[ ! -f "$HISTORY" ]]; then
  echo "No se encontró $HISTORY" >&2
  exit 1
fi

jq -rs "
  [.[] | select(
    .project == \"$PROJECT\"
    and (.display | test(\"^/exit|^/quit|^/remote-|^/clear\") | not)
  ) | \"## \" + (.timestamp/1000 | strftime(\"%Y-%m-%d %H:%M\")) + \"\\n> \" + .display]
  | .[]
" "$HISTORY"
