# Copia este archivo como .env y completa los valores reales
# NUNCA commitear .env — solo .env.sample

# OpenRouter (LLM via LangChain)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=your-preferred-model-here

# Base de datos
# DATABASE_URL=sqlite:///out/techo.db

# Storage (S3 o compatible)
# S3_BUCKET=your-bucket-name
# S3_ENDPOINT_URL=https://your-s3-endpoint
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# API
# API_PORT=8000
# API_HOST=0.0.0.0
